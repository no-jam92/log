---
import styles from './PrevNextNav.module.css';
import type { CollectionEntry } from 'astro:content';
import { getLang, t, postHref } from '../i18n/utils';

interface Props {
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}

const { prev, next } = Astro.props;
const lang = getLang(Astro.url);
const strings = t(lang);
---

<nav class={styles.nav} aria-label={`${strings.post.prev} / ${strings.post.next}`}>
  {prev ? (
    <a class={styles.card} href={postHref(prev.id, lang)}>
      <span class={styles.label}>← {strings.post.prev}</span>
      <span class={styles.title}>{prev.data.title}</span>
    </a>
  ) : (
    <span class={styles.placeholder} aria-hidden="true"></span>
  )}
  {next ? (
    <a class={`${styles.card} ${styles.next}`} href={postHref(next.id, lang)}>
      <span class={styles.label}>{strings.post.next} →</span>
      <span class={styles.title}>{next.data.title}</span>
    </a>
  ) : (
    <span class={styles.placeholder} aria-hidden="true"></span>
  )}
</nav>

---
import styles from './SiteHeader.module.css';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { site } from '../config/site';
import { getLang, t } from '../i18n/utils';

interface Props {
  /** 현재 활성 메뉴 키 — aria-current 표시에 사용 */
  current?: 'home' | 'about';
}

const { current } = Astro.props;
const lang = getLang(Astro.url);
const strings = t(lang);
const homeHref = lang === 'ko' ? '/' : '/en/';
const aboutHref = lang === 'ko' ? '/about' : '/en/about';
---

<header class={styles.header}>
  <div class={styles.inner}>
    <a class={styles.logo} href={homeHref} aria-label={`${strings.meta.siteName} ${strings.nav.home}`}>{site.logoMark}</a>
    <nav class={styles.nav} aria-label={strings.nav.home}>
      <a
        class={styles.navLink}
        href={homeHref}
        aria-current={current === 'home' ? 'page' : undefined}
      >
        {strings.nav.home}
      </a>
      <a
        class={styles.navLink}
        href={aboutHref}
        aria-current={current === 'about' ? 'page' : undefined}
      >
        {strings.nav.about}
      </a>
      <button class={styles.searchTrigger} type="button" data-search-open aria-label={strings.nav.searchLabel}>
        ⌘K
      </button>
      <LanguageSwitcher />
      <ThemeToggle />
    </nav>
  </div>
</header>

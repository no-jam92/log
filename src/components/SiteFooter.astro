---
import styles from './SiteFooter.module.css';
import { site } from '../config/site';
import { withBase } from '../i18n/utils';

const year = new Date().getFullYear();
const linkHref = (h: string) => (h.startsWith('/') ? withBase(h) : h);
---

<footer class={styles.footer}>
  <div class={styles.inner}>
    <p class={styles.copy}>© {year} {site.author.name}</p>
    <nav class={styles.links} aria-label="사이트 푸터">
      {site.author.social.map((s) => (
        <a class={styles.link} href={linkHref(s.href)}>{s.label}</a>
      ))}
    </nav>
    <span class={styles.build}>Build · {site.build}</span>
  </div>
</footer>

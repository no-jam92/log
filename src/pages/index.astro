---
import BaseLayout from '../layouts/BaseLayout.astro';
import YearGroup from '../components/YearGroup.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => data.lang === 'ko' && !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = post.data.date.getFullYear();
  const list = grouped.get(year) ?? [];
  list.push(post);
  grouped.set(year, list);
}
const years = Array.from(grouped.keys()).sort((a, b) => b - a);
const latestYear = years[0];
---

<BaseLayout title="조용한 서재" current="home">
  <div class="container">
    <header class="hero">
      <p class="label">QUIET STUDY · POSTS</p>
      <h1>글</h1>
      <p class="slogan"><em>A collection of thoughts, studies, and notes</em></p>
      <p class="count">총 {allPosts.length}편의 기록</p>
    </header>

    {allPosts.length === 0 ? (
      <p class="empty">아직 작성된 글이 없습니다.</p>
    ) : (
      years.map((year) => (
        <YearGroup year={year} posts={grouped.get(year)!} open={year === latestYear} />
      ))
    )}
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 0 var(--margin-sm);
  }
  .hero {
    margin-bottom: var(--section-gap);
  }
  .label {
    font-family: var(--label-family);
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    line-height: var(--label-leading);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--on-surface-variant);
    margin-bottom: var(--space-3);
  }
  h1 {
    font-family: var(--h1-family);
    font-size: var(--h1-mobile-size);
    font-weight: var(--h1-weight);
    line-height: var(--h1-leading);
    letter-spacing: var(--h1-tracking);
    margin-bottom: var(--space-3);
  }
  @media (min-width: 640px) {
    h1 { font-size: var(--h1-size); }
  }
  .slogan {
    font-family: var(--slogan-italic-family);
    font-style: var(--slogan-italic-style);
    font-size: var(--slogan-italic-size);
    color: var(--on-surface-variant);
    margin-bottom: var(--space-2);
  }
  .count {
    font-family: var(--meta-family);
    font-size: var(--meta-size);
    color: var(--on-surface-variant);
  }
  .empty {
    padding: var(--section-gap) 0;
    text-align: center;
    color: var(--on-surface-variant);
  }
</style>
